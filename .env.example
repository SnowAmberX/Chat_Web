# RAG API 基础地址（开发时留空走 Vite 代理）
VITE_API_BASE_URL=
# Python 聊天后端地址
VITE_CHAT_BACKEND_URL=http://localhost:9000
# Whisper 语音识别服务地址
VITE_WHISPER_URL=http://localhost:7860
# 聊天请求超时（毫秒）
VITE_CHAT_TIMEOUT_MS=15000
# 开发环境 Mock RAG 对话（true/false）
VITE_DEV_MOCK_RAG_CHAT=false
# Vite 代理目标（RAG API）
VITE_PROXY_TARGET=http://localhost:8000
# 应用标题
VITE_APP_TITLE=BNBU招生问答助手
