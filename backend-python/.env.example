# PostgreSQL
DATABASE_URL=postgresql://postgres:123456@127.0.0.1:5432/ai_chat

# SQLAlchemy connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# Python service
APP_HOST=0.0.0.0
APP_PORT=9000
APP_TIMEZONE=Asia/Shanghai

# ip2region xdb path
IP2REGION_DB_PATH=./ip2region/data/ip2region_v4.xdb
# ip2location .bin path(must be DB3 or higher version)
IP2LOCATION_DB_PATH=./ip2location/IP2LOCATION-LITE-DB3.BIN

# ==================== 邮件告警（关键词提醒邮件发送） ====================
# SMTP 服务器地址（必填，如 smtp.bnbu.edu.cn）
SMTP_HOST=
# SMTP 端口：465=SSL，587=TLS（默认 465）
SMTP_PORT=465
# aohelper@bnbu.edu.cn 的邮箱密码或授权码（必填）
SMTP_PASSWORD=